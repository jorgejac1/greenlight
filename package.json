{
  "name": "evalgate",
  "version": "0.10.2",
  "description": "Eval-gated todos for agentic coding. Your agents can't tick the checkbox until the verifier passes.",
  "type": "module",
  "bin": {
    "evalgate": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "hooks",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "node --test --import tsx test/*.test.ts",
    "prepare": "npm run build",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --write src/ test/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "claude-code",
    "codex",
    "mcp",
    "ai-agents",
    "agentic-workflow",
    "todo",
    "evals",
    "verifier",
    "coding-agent"
  ],
  "author": "Jorge Jacome",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
